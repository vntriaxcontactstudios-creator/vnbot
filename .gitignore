# VNBOT .gitignore

# === Build artifacts ===
*.zip
*.tar.gz
*.rar

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.coverage
htmlcov/
.tox/
.venv/
venv/
env/

# === Node ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# === Environment & secrets ===
.env
.env.local
.env.*.local
*.pem
*.key
secrets/
!.env.example

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# === Tool results & staging ===
tool-results/
scripts/_workspace_staging/

# === Large binary artifacts (use Git LFS or external storage) ===
# Keep PPTX out of git — they're regenerable from HTML slides
*.pptx
# Keep large ZIPs out
VNBOT_WORKSPACE_COMPLETE.zip

# === OS ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# === Logs ===
*.log
logs/

# === Database ===
*.sqlite
*.sqlite3
*.db

# === Temporary files ===
*.tmp
*.bak
*.cache

# === Vendor repos — artifacts to exclude (keep source code) ===
vendor/**/.git/
vendor/**/node_modules/
vendor/**/__pycache__/
vendor/**/dist/
vendor/**/build/
vendor/**/.next/
vendor/**/.turbo/
vendor/**/target/
vendor/**/.venv/
vendor/**/venv/
vendor/**/.pytest_cache/
vendor/**/*.egg-info/
vendor/**/coverage/
vendor/**/.nyc_output/
vendor/**/*.log
vendor/**/logs/
# Exclude lockfiles (regenerable, large)
vendor/**/package-lock.json
vendor/**/yarn.lock
vendor/**/pnpm-lock.yaml
vendor/**/poetry.lock
# Exclude model files (too large for git)
vendor/**/*.bin
vendor/**/*.pt
vendor/**/*.onnx
vendor/**/*.gguf
vendor/**/*.safetensors
# Exclude test fixtures with binary content
vendor/**/test-fixtures/
vendor/**/fixtures/binary/
